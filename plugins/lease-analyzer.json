  "field_validations": [
    {
      "field": "jurisdiction",
      "rule": "Require human review for legal/tax/country-specific rules; do not treat AI result as final authority."
    },
    {
      "field": "risk_tolerance",
      "rule": "Use selected risk tolerance to adjust severity labels and escalation threshold."
    },
    {
      "field": "fee_strictness",
      "rule": "Use selected risk tolerance to adjust severity labels and escalation threshold."
    },
    {
      "field": "language",
      "rule": "Preserve requested language in final deliverable unless source text requires bilingual output."
    }
  ],
  "scorecards": [
